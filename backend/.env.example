# Django
DJANGO_SETTINGS_MODULE=bikeshare.settings.local
DJANGO_SECRET_KEY=replace-me-with-a-real-secret-key

# PostgreSQL
POSTGRES_DB=bikeshare
POSTGRES_USER=bikeshare
POSTGRES_PASSWORD=bikeshare
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# MQTT (local dev)
MQTT_BROKER_TYPE=local
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883

# --- Production only (DJANGO_SETTINGS_MODULE=bikeshare.settings.production) ---
# All of these are REQUIRED in production — the server will refuse to start without them.
# DJANGO_SETTINGS_MODULE=bikeshare.settings.production
# DJANGO_SECRET_KEY=<strong-random-key>
# ALLOWED_HOSTS=api.yourdomain.com
# AWS_REGION=us-east-1
# AWS_IOT_ENDPOINT=xxxxxxxxxxxxxxx-ats.iot.us-east-1.amazonaws.com
#
# SMS OTP (AWS SNS):
# No additional env vars needed — the ECS task role (provisioned by CDK) grants
# sns:Publish automatically. Phones must be in E.164 format (e.g. +12345678900).
# In DEBUG mode, SMS is skipped and the OTP is returned in the API response.
